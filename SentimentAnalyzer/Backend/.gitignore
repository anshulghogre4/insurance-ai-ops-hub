## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Configuration files with secrets
appsettings.Development.json
appsettings.Local.json
appsettings.*.json
!appsettings.json
.env
.env.*

# Visual Studio
.vs/
*.log
*.vspscc
*.vssscc
.builds

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet
*.nupkg
**/packages/*
!**/packages/build/

# Others
*.cache
*.dbmdl
*.jfm
project.lock.json
project.fragment.lock.json
artifacts/
