    },
    "HuggingFace": {
      "ApiKey": "",
      "NerModel": "dslim/bert-base-NER"
    }
  },
  "AgentConfiguration": {
    "MaxAgentTurns": 15,
    "TimeoutSeconds": 60,
    "IncludeArchitectAgent": true,
    "FallbackToSimpleAnalysis": true
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=insurance_analysis.db"
  },
  "Supabase": {
    "Url": "",
    "AnonKey": "",
    "JwtSecret": ""
